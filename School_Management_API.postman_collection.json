		"description": "API collection for School Management system including Add School and List Schools by proximity.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Add School",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Delhi Public School\",\n    \"address\": \"Sector 12, New Delhi, India\",\n    \"latitude\": 28.6139,\n    \"longitude\": 77.2090\n}"
				},
				"url": {
					"raw": "{{base_url}}/addSchool",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"addSchool"
					]
				},
				"description": "Adds a new school to the database. Requires name, address, latitude, and longitude."
			},
			"response": []
		},
		{
			"name": "List Schools",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/listSchools?latitude=28.5000&longitude=77.1000",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"listSchools"
					],
					"query": [
						{
							"key": "latitude",
							"value": "28.5000"
						},
						{
							"key": "longitude",
							"value": "77.1000"
						}
					]
				},
				"description": "Retrieves a list of schools sorted by proximity to the specified latitude and longitude."
			},
			"response": []
		}
	],
